WS_PORT=8080

# OpenAI Realtime
OPENAI_API_KEY=sk-...
REALTIME_TRANSPORT=openai_sdk
REALTIME_API_BASE_URL=https://api.openai.com/v1
REALTIME_URL=wss://api.openai.com/v1/realtime
REALTIME_MODEL=gpt-4o-realtime-preview
REALTIME_BETA_HEADER=1
REALTIME_SCHEMA=flat
REALTIME_AUDIO_MODE=pcmu
REALTIME_AUDIO_RATE=24000
REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
REALTIME_VAD_SILENCE_MS=800
REALTIME_INTERRUPT_RESPONSE=1
BARGE_IN_CANCEL=0

# State machine behavior
SILENCE_TIMEOUT_MS=7000
SILENCE_RETRIES_MAX=2
NOHEAR_RETRIES_MAX=2
SILENCE_AUTO_PROMPT=1
NOHEAR_AUTO_PROMPT=0
STT_CONFIDENCE_THRESHOLD=0.55
CORRECTION_KEYWORDS=やっぱり,違う,他の,間違えた,キャンセル
ORDER_RETRY_MAX=1
DELIVERY_RETRY_MAX=1

# External services
TOOL_BASE_URL=http://127.0.0.1:19002
TOOL_STOCK_TIMEOUT_MS=4000
TOOL_PRICE_TIMEOUT_MS=4000
TOOL_DELIVERY_TIMEOUT_MS=6000
TOOL_ORDER_TIMEOUT_MS=4000
LOG_API_BASE_URL=http://127.0.0.1:3002
LOG_API_TIMEOUT_MS=3000

# Optional
PRODUCT_CATALOG_PATH=
TEST_PROMPT=
TEST_TWILIO_TONE=0
